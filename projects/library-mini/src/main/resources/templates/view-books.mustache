{{>partials/header}}

<div class="container-fluid">
    <div class="row">

        {{>partials/sidebar}}

        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10">

            <div class="page-header header-with-btn">
                <h1 class="h2">
                    <i class="bi bi-book-fill me-2"></i>Books Library
                </h1>

                <a href="/BookController?action=showAddBook" class="btn-modern">
                    <i class="bi bi-plus-circle"></i>Add New Book
                </a>
            </div>

            {{#successMessage}}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{successMessage}}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {{/successMessage}}

            <!-- Books Table -->
            <div class="table-container">
                <div class="table-responsive">

                    <table class="table table-hover align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Category</th>
                            <th>ISBN</th>
                            <th>Actions</th>
                        </tr>
                        </thead>

                        <tbody>
                        {{#books}}
                            <tr>
                                <td><span class="badge bg-primary">{{bookId}}</span></td>

                                <td><strong>{{title}}</strong></td>
                                <td>{{author}}</td>

                                <td><span class="badge badge-modern badge-fiction">{{category}}</span></td>

                                <td><code>{{isbn}}</code></td>


                                <td>
                                    <a href="/BookController?action=viewBook&bookId={{bookId}}" class="action-btn edit" title="Edit Book">
                                    <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <button class="action-btn delete" title="Delete Book">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        {{/books}}
                        </tbody>
                    </table>

                    {{^books}}
                        <div>No books found</div>
                    {{/books}}

                </div>
            </div>

        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
